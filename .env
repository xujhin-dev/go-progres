# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres

# Redis 配置
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=test-secret-key-for-development-only-32-chars
JWT_EXPIRE=24

# 应用配置
GIN_MODE=debug
SERVER_PORT=8080
TEST_OTP_CODE=123456

# 监控配置
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# GitHub 配置 (用于 CI/CD)
GITHUB_REPOSITORY=your-org/go-progres

# OSS 配置 (可选)
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=test_access_key
OSS_ACCESS_KEY_SECRET=test_access_secret
OSS_BUCKET_NAME=test_bucket

# 推送服务配置 (可选)
PUSH_ACCESS_KEY_ID=test_push_key
PUSH_ACCESS_KEY_SECRET=test_push_secret
PUSH_APP_KEY=12345678
PUSH_REGION_ID=cn-hangzhou

# 支付宝配置 (可选)
ALIPAY_APP_ID=test_app_id
ALIPAY_PRIVATE_KEY_PATH=./test_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./test_alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://yourdomain.com/payment/notify/alipay
ALIPAY_RETURN_URL=https://yourdomain.com/payment/return
ALIPAY_IS_PRODUCTION=false

# 微信支付配置 (可选)
WECHAT_APP_ID=test_app_id
WECHAT_MCH_ID=test_mch_id
WECHAT_MCH_CERT_SERIAL=test_cert_serial
WECHAT_MCH_PRIVATE_KEY_PATH=./test_apiclient_key.pem
WECHAT_APIV3_KEY=test_apiv3_key
WECHAT_NOTIFY_URL=https://yourdomain.com/payment/notify/wechat

# 通知配置 (可选)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=test@gmail.com
EMAIL_PASSWORD=test_password
